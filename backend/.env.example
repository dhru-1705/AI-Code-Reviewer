# Server Port
PORT=5000

# MongoDB Connection String (Atlas or Local)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/ai-code-reviewer?retryWrites=true&w=majority

# JWT Token Secret and Expiration
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Groq API Configuration
GROQ_API_KEY=gsk_your_groq_api_key_goes_here
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: Gemini API Configuration (for easy switching later)
GEMINI_API_KEY=your_gemini_api_key_goes_here
